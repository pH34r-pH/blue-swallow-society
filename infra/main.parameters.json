{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": { "value": "westus2" },
    "postgresLocation": { "value": "westus3" },
    "staticWebAppName": { "value": "blue-swallow-swa" },
    "prefix": { "value": "blue-swallow" },
    "allowedSourceIp": {
      "value": "*",
      "metadata": {
        "description": "WARNING: '*' exposes ports 22 and 8080 to the entire internet. Set to your IP before production."
      }
    },
    "vmSize": { "value": "Standard_B1ms" },
    "deployOpenAi": { "value": false },
    "autoShutdownTime": { "value": "0200" },
    "autoShutdownTimeZone": { "value": "Pacific Standard Time" },
    "enableAutoShutdown": { "value": false },
    "postgresServerName": { "value": "blue-swallow-pg" },
    "postgresDatabaseName": { "value": "cybermap" },
    "postgresAdministratorLogin": { "value": "bssadmin" },
    "postgresSkuName": { "value": "Standard_B1ms" },
    "postgresStorageSizeGiB": { "value": 32 },
    "postgresBackupRetentionDays": { "value": 7 }
  }
}
